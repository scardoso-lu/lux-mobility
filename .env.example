# Copy to .env and fill in values before running docker-compose
PG_USER=lux_user
PG_PASS=lux_pass
PG_DB=lux_mobility
PG_PORT=5432
PG_HOST=postgres

# Set to true to wipe processed files and PG tables and re-run the full ETL
FORCE_REPROCESS=false

# Public-facing URLs (used by the frontend at runtime)
TILE_URL=http://localhost:3000
API_URL=http://localhost:8000
